"""Composite quality scorer — §1.2 formula."""


def rubric_to_utility(rubric: dict) -> float:
    """
    §11.1 normalization:
      raw = findings_clarity + open_questions_q + evidence_depth + frontier_signal + noise_penalty
      utility_0_10 = max(0, min(10, (raw + 2) * 10 / 11))

    raw range: -2..9
    """
    raw = (
        rubric.get("findings_clarity", 0)
        + rubric.get("open_questions_q", 0)
        + rubric.get("evidence_depth", 0)
        + rubric.get("frontier_signal", 0)
        + rubric.get("noise_penalty", 0)
    )
    return round(max(0.0, min(10.0, (raw + 2) * 10 / 11)), 4)


def compute_quality(h_struct: float, utility: float) -> float:
    """
    §1.2: quality = 0.35 * h_struct/100 + 0.65 * utility/10
    Returns value in [0, 1].
    """
    return round(0.35 * (h_struct / 100.0) + 0.65 * (utility / 10.0), 4)
