import re
from dataclasses import dataclass
from typing import Optional

_OPEN_RE = re.compile(r"<!--claim:(\d+)-->")
_CLOSE_RE = re.compile(r"<!--/claim:(\d+)-->")
_MARKER_STRIP_RE = re.compile(r"<!--/?claim:\d+-->")
_TOPIC_STRIP_RE = re.compile(r"<!--topic:\d+-->")

def _compute_forbidden_ranges(content: str) -> list[tuple[int, int]]:
    forbidden: list[tuple[int, int]] = []
    for m in re.finditer(r"```.*?```", content, re.DOTALL): forbidden.append((m.start(), m.end()))
    for m in re.finditer(r"`[^`\n]+`", content): forbidden.append((m.start(), m.end()))
    for m in re.finditer(r"^#{1,3} .+$", content, re.MULTILINE): forbidden.append((m.start(), m.end()))
    for m in re.finditer(r"\[([^\]]+)\]\([^\)]+\)", content): forbidden.append((m.start(), m.start() + len(m.group(0))))
    for pattern in [r"\*\*[^*\n]+\*\*", r"__[^_\n]+__"]:
        for m in re.finditer(pattern, content): forbidden.append((m.start(), m.end()))
    for m in re.finditer(r"\$[^$\n]+\$", content): forbidden.append((m.start(), m.end()))
    for m in re.finditer(r"\$\$.*?\$\$", content, re.DOTALL): forbidden.append((m.start(), m.end()))
    for m in re.finditer(r"^[ \t]*(?:[-*+]|\d+\.)\s", content, re.MULTILINE): forbidden.append((m.start(), m.end()))
    for m in _MARKER_STRIP_RE.finditer(content): forbidden.append((m.start(), m.end()))
    return forbidden

def _in_forbidden(start: int, end: int, forbidden: list[tuple[int, int]]) -> bool:
    for fs, fe in forbidden:
        if start < fe and end > fs: return True
    return False

@dataclass
class InjectionCandidate:
    claim_id: int
    chosen_sentence: str
    span: str
    confidence: float
    judge_agreement: float
    match_type: str = "verbatim"
    chosen_section: str = ""

@dataclass
class InjectionResult:
    content: str
    injected_count: int
    skipped_ambiguous: int
    skipped_unsafe: int
    validation_errors: list[str]
    topical_anchor_count: int = 0

def strip_markers(content: str) -> str:
    content = _MARKER_STRIP_RE.sub("", content)
    content = _TOPIC_STRIP_RE.sub("", content)
    return content

def inject_markers(content: str, candidates: list[InjectionCandidate]) -> InjectionResult:
    import json
    
    with open("/tmp/injector_debug.log", "w") as f:
        f.write(f"1. candidates_in (After judge gate): {len(candidates)}\n")
        
        sentence_claims = {}
        for cand in candidates:
            if cand.match_type == "topic": continue
            key = cand.chosen_sentence
            if key not in sentence_claims:
                sentence_claims[key] = []
            sentence_claims[key].append(cand)
            
        sentence_best: dict[str, InjectionCandidate] = {}
        topical_cands = []
        for cand in candidates:
            if cand.match_type == "topic":
                topical_cands.append(cand)
                continue
            key = cand.chosen_sentence
            if key not in sentence_best or cand.confidence > sentence_best[key].confidence:
                sentence_best[key] = cand
                
        deduped = list(sentence_best.values())
        
        f.write(f"2. after_sentence_dedup: {len(deduped)}\n")
        collapsed = len([c for c in candidates if c.match_type != "topic"]) - len(deduped)
        f.write(f"   collapsed_claims: {collapsed}\n")
        
        top_sentences = sorted(sentence_claims.items(), key=lambda x: len(x[1]), reverse=True)[:5]
        f.write("\nTop 5 sentences absorbing claims:\n")
        for sent, cands in top_sentences:
            f.write(f"--- Sentence ({len(cands)} claims): {sent}\n")
            for c in cands:
                f.write(f"    claim_id: {c.claim_id}, conf: {c.confidence}, match_type: {c.match_type}\n")

    # content = strip_markers(content) # Removed: caller handles stripping
    forbidden = _compute_forbidden_ranges(content)

    @dataclass
    class PlacedInjection:
        claim_id: int
        span: str
        content_pos: int
        is_topic: bool = False

    placed: list[PlacedInjection] = []
    skipped_ambiguous = 0
    skipped_unsafe = 0

    for cand in deduped:
        span = cand.span
        occurrences = [m.start() for m in re.finditer(re.escape(span), content)]
        if len(occurrences) == 0:
            sent_pos = content.find(cand.chosen_sentence)
            if sent_pos >= 0:
                sub = content[sent_pos: sent_pos + len(cand.chosen_sentence)]
                sub_idx = sub.find(span)
                if sub_idx >= 0:
                    occurrences = [sent_pos + sub_idx]
        if len(occurrences) == 0:
            skipped_ambiguous += 1
            continue
        if len(occurrences) > 1:
            sent_pos = content.find(cand.chosen_sentence)
            if sent_pos >= 0:
                span_in_sent = content.find(span, sent_pos)
                if span_in_sent >= 0 and span_in_sent < sent_pos + len(cand.chosen_sentence):
                    occurrences = [span_in_sent]
                else:
                    skipped_ambiguous += 1
                    continue
            else:
                skipped_ambiguous += 1
                continue

        pos = occurrences[0]
        span_end = pos + len(span)
        if _in_forbidden(pos, span_end, forbidden):
            skipped_unsafe += 1
            continue
        placed.append(PlacedInjection(claim_id=cand.claim_id, span=span, content_pos=pos))

    with open("/tmp/injector_debug.log", "a") as f:
        f.write(f"\n3. after_ambiguity_check (dropped {skipped_ambiguous}): {len(deduped) - skipped_ambiguous}\n")
        f.write(f"4. after_forbidden_check (dropped {skipped_unsafe}): {len(placed)}\n")
        f.write(f"5. final_injected: {len(placed)}\n")

    topic_claims_by_section = {}
    for cand in topical_cands:
        if cand.chosen_section not in topic_claims_by_section:
            topic_claims_by_section[cand.chosen_section] = set()
        topic_claims_by_section[cand.chosen_section].add(cand.claim_id)

    for sec_title, cids in topic_claims_by_section.items():
        m = re.search(r"^(#{1,3})\s+" + re.escape(sec_title) + r"\s*$", content, re.MULTILINE)
        if m:
            insert_pos = m.end() + 1
            for cid in sorted(list(cids)):
                placed.append(PlacedInjection(claim_id=cid, span="", content_pos=insert_pos, is_topic=True))

    placed.sort(key=lambda x: x.content_pos, reverse=True)
    
    result = content
    topical_count = 0
    injected_count = 0
    for inj in placed:
        pos = inj.content_pos
        if inj.is_topic:
            tag = f"<!--topic:{inj.claim_id}-->"
            result = result[:pos] + tag + result[pos:]
            topical_count += 1
        else:
            open_tag = f"<!--claim:{inj.claim_id}-->"
            close_tag = f"<!--/claim:{inj.claim_id}-->"
            span_len = len(inj.span)
            result = result[:pos] + open_tag + inj.span + close_tag + result[pos + span_len:]
            injected_count += 1

    validation_errors = _validate(result, injected_count)

    return InjectionResult(
        content=result,
        injected_count=injected_count,
        skipped_ambiguous=skipped_ambiguous,
        skipped_unsafe=skipped_unsafe,
        validation_errors=validation_errors,
        topical_anchor_count=topical_count
    )

def _validate(content: str, expected_injected: int) -> list[str]:
    errors: list[str] = []
    opens = _OPEN_RE.findall(content)
    closes = _CLOSE_RE.findall(content)
    if sorted(opens) != sorted(closes):
        errors.append(f"unmatched_markers: opens={len(opens)} closes={len(closes)}")
    if len(opens) != expected_injected:
        errors.append(f"marker_count_mismatch: found={len(opens)} expected={expected_injected}")
    if len(opens) != len(set(opens)):
        dupes = [x for x in opens if opens.count(x) > 1]
        errors.append(f"duplicate_marker_ids: {set(dupes)}")
    frontend_matches = re.findall(r"<!--claim:(\d+)-->.*?<!--/claim:\1-->", content, re.DOTALL)
    if len(frontend_matches) != expected_injected:
        errors.append(f"frontend_smoke_fail: matched={len(frontend_matches)} expected={expected_injected}")
    return errors
