+#!/usr/bin/env python3
+"""Dry-run paper-intro staking loop for page 58 sentence trust.
+
+Slice-1 only:
+- SELECTs existing page 58 sentence_trust / sentence_provenance / paper_intros.
+- Does not run Alembic, insert sentence_votes, update sentence_trust, or write page data.
+- Writes JSON + Markdown artifacts under docs/.
+"""
+from __future__ import annotations
+
+import argparse
+import collections
+import datetime as dt
+import hashlib
+import importlib.util
+import json
+import math
+import os
+import re
+import statistics
+import sys
+import time
+import urllib.request
+from pathlib import Path
+from typing import Any
+
+from sqlalchemy import create_engine, text
+
+
+REPO_ROOT = Path(__file__).resolve().parents[2]
+BACKEND_ROOT = Path(__file__).resolve().parents[1]
+DOCS_ROOT = REPO_ROOT / "docs"
+DSN = os.getenv("DATABASE_URL", "postgresql://nebula:nebula@localhost:5432/nebulamind")
+OLLAMA_BASE = os.getenv("PAGE58_STAKING_OLLAMA_BASE", "http://localhost:11434").rstrip("/")
+ATOM_MODEL = "vanta-research/atom-astronomy-7b:latest"
+EMBED_MODEL = "qwen3-embedding:4b"
+TONE_GATE = Path(
+    "/Users/duhokim/.openclaw/workspace/galaxy_evolution_v2/"
+    "tone_gold_locked_3tier_env_quenching_20260617T104227Z/"
+    "model_score_3tier_20260617T104331Z/complete_and_score.py"
+)
+TONE_PROMPT = TONE_GATE.with_name("mima_prompt.txt")
+PAGE_SLUG = "galaxy-evolution-v2"
+PAGE_ID = 58
+TAU_REL_DEFAULT = 0.55
+TAU_VOTE_DEFAULT = 0.70
+ATOM_BATCH = 24
+
+
+def utc_stamp() -> str:
+    return dt.datetime.now(dt.UTC).strftime("%Y%m%dT%H%M%SZ")
+
+
+def sha256_text(value: str) -> str:
+    return hashlib.sha256(value.encode("utf-8")).hexdigest()
+
+
+def write_json(path: Path, payload: Any) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True), encoding="utf-8")
+
+
+def write_jsonl(path: Path, rows: list[dict[str, Any]]) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    with path.open("w", encoding="utf-8") as handle:
+        for row in rows:
+            handle.write(json.dumps(row, ensure_ascii=False, sort_keys=True) + "\n")
+
+
+def read_jsonl(path: Path) -> list[dict[str, Any]]:
+    if not path.exists():
+        return []
+    return [json.loads(line) for line in path.read_text(encoding="utf-8").splitlines() if line.strip()]
+
+
+def strip_badge(line: str) -> str:
+    return re.sub(r"\s*\[[^\]]*(?:intros|settled|contested|established|debated)[^\]]*\]\s*$", "", line).strip()
+
+
+def split_sentences(text_value: str) -> list[str]:
+    text_value = re.sub(r"\s+", " ", text_value or "").strip()
+    if not text_value:
+        return []
+    parts = re.split(r"(?<=[.!?])\s+(?=[A-Z0-9])", text_value)
+    out: list[str] = []
+    for part in parts:
+        clean = part.strip()
+        if len(clean) < 50 or len(clean) > 900:
+            continue
+        if clean.count(" ") < 7:
+            continue
+        out.append(clean)
+    return out
+
+
+def cosine(left: list[float], right: list[float]) -> float:
+    dot = sum(a * b for a, b in zip(left, right))
+    nl = math.sqrt(sum(a * a for a in left))
+    nr = math.sqrt(sum(b * b for b in right))
+    return dot / (nl * nr) if nl and nr else 0.0
+
+
+def extract_json(raw: str) -> dict[str, Any]:
+    raw = raw.strip()
+    try:
+        return json.loads(raw)
+    except Exception:
+        pass
+    match = re.search(r"```(?:json)?\s*(\{.*?\})\s*```", raw, re.S)
+    if match:
+        return json.loads(match.group(1))
+    start = raw.find("{")
+    end = raw.rfind("}")
+    if start >= 0 and end > start:
+        return json.loads(raw[start : end + 1])
+    raise ValueError("no parseable JSON")
+
+
+def ollama_chat_json(model: str, system: str, user: str, timeout: int = 180) -> dict[str, Any]:
+    payload = {
+        "model": model,
+        "messages": [{"role": "system", "content": system}, {"role": "user", "content": user}],
+        "stream": False,
+        "format": "json",
+        "think": False,
+        "options": {"temperature": 0},
+    }
+    data = json.dumps(payload).encode("utf-8")
+    request = urllib.request.Request(
+        f"{OLLAMA_BASE}/api/chat",
+        data=data,
+        headers={"Content-Type": "application/json"},
+        method="POST",
+    )
+    with urllib.request.urlopen(request, timeout=timeout) as response:
+        raw = json.loads(response.read().decode("utf-8"))
+    content = ((raw.get("message") or {}).get("content") or "").strip()
+    return extract_json(content)
+
+
+def embed_texts(texts: list[str], timeout: int = 180) -> list[list[float]]:
+    if not texts:
+        return []
+    payload = {"model": EMBED_MODEL, "input": texts, "truncate": True}
+    data = json.dumps(payload).encode("utf-8")
+    request = urllib.request.Request(
+        f"{OLLAMA_BASE}/api/embed",
+        data=data,
+        headers={"Content-Type": "application/json"},
+        method="POST",
+    )
+    with urllib.request.urlopen(request, timeout=timeout) as response:
+        raw = json.loads(response.read().decode("utf-8"))
+    embeddings = raw.get("embeddings")
+    if not isinstance(embeddings, list):
+        raise RuntimeError(f"unexpected embedding response keys={list(raw)}")
+    return embeddings
+
+
+def heuristic_finding(sentence: str) -> tuple[bool, float, str]:
+    s = sentence.lower()
+    positive = [
+        "we find", "we show", "we demonstrate", "we reveal", "we report",
+        "results indicate", "results suggest", "we conclude", "our analysis",
+        "we measure", "we infer", "is consistent with", "evidence for",
+    ]
+    negative = ["we use", "we present observations", "we describe", "this paper", "we introduce"]
+    if any(p in s for p in positive):
+        return True, 0.62, "heuristic_finding_phrase"
+    if any(n in s for n in negative):
+        return False, 0.58, "heuristic_method_or_background"
+    return False, 0.45, "heuristic_no_finding_cue"
+
+
+def atom_claim_filter(sentences: list[str], timeout: int) -> list[dict[str, Any]]:
+    system = (
+        "You are Atom-Astronomy-7B. Classify astronomy introduction sentences. "
+        "Return strict JSON only: {\"items\":[{\"id\":\"...\",\"label\":\"finding|background\","
+        "\"confidence\":0.0,\"reason\":\"short\"}]}. Use finding for a concrete result, "
+        "measurement, conclusion, or claim that can stake a wiki sentence. Use background for "
+        "motivation, methods, survey descriptions, and generic context."
+    )
+    results: list[dict[str, Any]] = []
+    for offset in range(0, len(sentences), ATOM_BATCH):
+        chunk = sentences[offset : offset + ATOM_BATCH]
+        payload = [{"id": str(offset + i), "text": text_value} for i, text_value in enumerate(chunk)]
+        user = "Input sentences JSON:\n" + json.dumps(payload, ensure_ascii=False)
+        parsed_items: dict[str, dict[str, Any]] = {}
+        try:
+            obj = ollama_chat_json(ATOM_MODEL, system, user, timeout=timeout)
+            for item in obj.get("items") or []:
+                if isinstance(item, dict) and "id" in item:
+                    parsed_items[str(item["id"])] = item
+        except Exception:
+            parsed_items = {}
+        for i, sentence in enumerate(chunk):
+            sid = str(offset + i)
+            item = parsed_items.get(sid)
+            if item:
+                label = str(item.get("label") or "background").strip().lower()
+                try:
+                    conf = float(item.get("confidence") or 0.0)
+                except (TypeError, ValueError):
+                    conf = 0.0
+                results.append({
+                    "sentence": sentence,
+                    "finding": label == "finding" and conf >= 0.50,
+                    "confidence": conf,
+                    "source": ATOM_MODEL,
+                    "reason": str(item.get("reason") or "")[:200],
+                })
+            else:
+                finding, conf, reason = heuristic_finding(sentence)
+                results.append({
+                    "sentence": sentence,
+                    "finding": finding,
+                    "confidence": conf,
+                    "source": "heuristic_fallback_after_atom_parse_error",
+                    "reason": reason,
+                })
+    return results
+
+
+def load_tone_gate():
+    spec = importlib.util.spec_from_file_location("tone_gate_complete_and_score", TONE_GATE)
+    if spec is None or spec.loader is None:
+        raise RuntimeError(f"cannot load tone gate {TONE_GATE}")
+    module = importlib.util.module_from_spec(spec)
+    spec.loader.exec_module(module)
+    return module
+
+
+def tone_gate_predictions(pairs: list[dict[str, Any]], timeout: int) -> list[dict[str, Any]]:
+    if not pairs:
+        return []
+    module = load_tone_gate()
+    module.TIMEOUT = timeout
+    system = TONE_PROMPT.read_text(encoding="utf-8")
+    rows = [
+        {
+            "locked_gold_id": pair["pair_id"],
+            "assertion_text": (
+                "Intro finding: " + pair["intro_sentence"] + "\n"
+                "Base sentence: " + pair["base_sentence"] + "\n"
+                "Classify the intro finding's certainty/tone in relation to the base sentence."
+            ),
+        }
+        for pair in pairs
+    ]
+    preds = module.predict_mima(rows, system)
+    out: list[dict[str, Any]] = []
+    for pair in pairs:
+        tier4, conf, rationale, elapsed = preds.get(pair["pair_id"], (None, 0.0, "missing", 0.0))
+        tier4 = str(tier4 or "accepted").lower()
+        if tier4 not in {"consensus", "accepted", "debated", "challenged"}:
+            tier4 = "accepted"
+        out.append({
+            **pair,
+            "tone_tier": tier4,
+            "tone_confidence": float(conf or 0.0),
+            "tone_rationale": str(rationale or "")[:220],
+            "tone_gate_model": getattr(module, "MIMA_MODEL", "tone_gate_predict_mima"),
+            "tone_gate_elapsed_batch_seconds": float(elapsed or 0.0),
+        })
+    return out
+
+
+def stance_from_tone(tone_tier: str, confidence: float, tau_vote: float) -> tuple[str, int | None]:
+    if confidence < tau_vote:
+        return "no_op", None
+    if tone_tier in {"consensus", "accepted"}:
+        return "agree", 1
+    if tone_tier == "challenged":
+        return "disagree", -1
+    if tone_tier == "debated":
+        return "refine", None
+    return "neutral", None
+
+
+def trust_level(pro: int, con: int, distinct_sources: int) -> str:
+    total = pro + con
+    if total <= 0 or distinct_sources <= 0:
+        return "unverified"
+    if distinct_sources == 1:
+        return "unverified"
+    share = pro / total if total else 0.0
+    if con > pro:
+        return "challenged"
+    if con > 0:
+        return "debated" if share < 0.90 else "accepted"
+    if pro >= 3:
+        return "consensus"
+    return "accepted"
+
+
+def rollup(base_rows: list[dict[str, Any]], votes: list[dict[str, Any]], tau_vote: float, drop_con: bool = False) -> list[dict[str, Any]]:
+    by_sentence = {int(row["sentence_index"]): row for row in base_rows}
+    grouped: dict[int, dict[str, Any]] = {
+        idx: {"pro": 0, "con": 0, "papers": set(), "refine": 0, "no_op": 0}
+        for idx in by_sentence
+    }
+    best: dict[tuple[int, str], dict[str, Any]] = {}
+    for vote in votes:
+        stance, value = stance_from_tone(vote["tone_tier"], float(vote["tone_confidence"]), tau_vote)
+        vote["stance_at_tau"] = stance
+        vote["value_at_tau"] = value
+        idx = int(vote["sentence_index"])
+        if stance == "refine":
+            grouped[idx]["refine"] += 1
+            continue
+        if stance in {"no_op", "neutral"} or value is None:
+            grouped[idx]["no_op"] += 1
+            continue
+        if drop_con and value < 0:
+            continue
+        key = (idx, str(vote["arxiv_id"]))
+        prior = best.get(key)
+        if prior is None or float(vote["tone_confidence"]) > float(prior["tone_confidence"]):
+            best[key] = {**vote, "value": value}
+    for (idx, arxiv_id), vote in best.items():
+        grouped[idx]["papers"].add(arxiv_id)
+        if int(vote["value"]) > 0:
+            grouped[idx]["pro"] += 1
+        else:
+            grouped[idx]["con"] += 1
+    rows: list[dict[str, Any]] = []
+    for idx, base in by_sentence.items():
+        new = grouped[idx]
+        existing_pro = int(base.get("settled_votes") or 0)
+        existing_con = int(base.get("contested_votes") or 0)
+        existing_sources = set(base.get("existing_arxiv_ids") or [])
+        pro = existing_pro + new["pro"]
+        con = existing_con + new["con"]
+        distinct_sources = len(existing_sources | new["papers"])
+        total = pro + con
+        share = pro / total if total else 0.0
+        level = trust_level(pro, con, distinct_sources)
+        rows.append({
+            "page_version_id": base["page_version_id"],
+            "sentence_index": idx,
+            "sentence_hash": base["sentence_hash"],
+            "sentence_text": base["sentence_text"],
+            "baseline_trust_level": base["trust_level"],
+            "baseline_settled_votes": existing_pro,
+            "baseline_contested_votes": existing_con,
+            "new_pro_votes": new["pro"],
+            "new_con_votes": new["con"],
+            "refine_tally": new["refine"],
+            "no_op_tally": new["no_op"],
+            "would_be_settled_votes": pro,
+            "would_be_contested_votes": con,
+            "would_be_vote_count": distinct_sources,
+            "settled_share": round(share, 6),
+            "trust_score": round(0.45 * ((pro - con) / (total + 0.001)), 6) if total else 0.0,
+            "would_be_trust_level": level,
+            "single_source": distinct_sources == 1,
+        })
+    return rows
+
+
+def load_base_and_intros(limit_intros: int | None) -> tuple[list[dict[str, Any]], list[dict[str, Any]], dict[str, Any]]:
+    engine = create_engine(DSN)
+    with engine.connect() as conn:
+        page = conn.execute(
+            text("SELECT id, slug, title FROM wiki_pages WHERE id=:page_id AND slug=:slug"),
+            {"page_id": PAGE_ID, "slug": PAGE_SLUG},
+        ).mappings().one()
+        pv = conn.execute(
+            text(
+                """
+                SELECT pv.id, pv.version_num, pv.content
+                FROM page_versions pv
+                WHERE pv.page_id=:page_id
+                  AND EXISTS (
+                      SELECT 1 FROM sentence_trust st WHERE st.page_version_id=pv.id
+                  )
+                ORDER BY pv.id DESC
+                LIMIT 1
+                """
+            ),
+            {"page_id": PAGE_ID},
+        ).mappings().one()
+        trust_rows = conn.execute(
+            text(
+                """
+                SELECT page_version_id, sentence_index, sentence_hash, trust_level,
+                       vote_count, settled_votes, contested_votes, settled_share
+                FROM sentence_trust
+                WHERE page_version_id=:pv
+                ORDER BY sentence_index
+                """
+            ),
+            {"pv": pv["id"]},
+        ).mappings().all()
+        provenance = conn.execute(
+            text(
+                """
+                SELECT sentence_index, arxiv_id
+                FROM sentence_provenance
+                WHERE page_version_id=:pv AND arxiv_id IS NOT NULL
+                """
+            ),
+            {"pv": pv["id"]},
+        ).mappings().all()
+        sql = """
+            SELECT arxiv_id, intro_text, source, fetched_at
+            FROM paper_intros
+            WHERE intro_text IS NOT NULL AND length(intro_text) > 50
+            ORDER BY arxiv_id
+        """
+        if limit_intros:
+            sql += " LIMIT :limit"
+            intro_rows = conn.execute(text(sql), {"limit": limit_intros}).mappings().all()
+        else:
+            intro_rows = conn.execute(text(sql)).mappings().all()
+    lines = [
+        strip_badge(line)
+        for line in str(pv["content"]).splitlines()
+        if line.strip() and not line.strip().startswith("#")
+    ]
+    if len(lines) < len(trust_rows):
+        raise RuntimeError(f"could not extract base sentences: lines={len(lines)} trust_rows={len(trust_rows)}")
+    prov_by_idx: dict[int, set[str]] = collections.defaultdict(set)
+    for row in provenance:
+        prov_by_idx[int(row["sentence_index"])].add(str(row["arxiv_id"]))
+    base: list[dict[str, Any]] = []
+    for row in trust_rows:
+        idx = int(row["sentence_index"])
+        base.append({
+            **dict(row),
+            "sentence_text": lines[idx],
+            "existing_arxiv_ids": sorted(prov_by_idx[idx]),
+        })
+    return base, [dict(row) for row in intro_rows], {"page": dict(page), "page_version": {"id": pv["id"], "version_num": pv["version_num"]}}
+
+
+def run(args: argparse.Namespace) -> dict[str, Any]:
+    if not args.no_apply:
+        raise SystemExit("Refusing to run without --no-apply")
+    if os.getenv("NM_ANTHROPIC_API_KEY"):
+        raise SystemExit("Refusing to run with NM_ANTHROPIC_API_KEY set")
+    started = time.time()
+    timings: dict[str, float] = {}
+    base, intros, meta = load_base_and_intros(args.limit_intros)
+    timings["load_seconds"] = round(time.time() - started, 3)
+
+    t0 = time.time()
+    base_embeddings = embed_texts([row["sentence_text"] for row in base], timeout=args.model_timeout)
+    timings["base_embedding_seconds"] = round(time.time() - t0, 3)
+
+    findings: list[dict[str, Any]] = []
+    filtered_count = 0
+    sentence_count = 0
+    per_intro: dict[str, dict[str, Any]] = {}
+    t0 = time.time()
+    for intro in intros:
+        sentences = split_sentences(str(intro.get("intro_text") or ""))
+        sentence_count += len(sentences)
+        classified = atom_claim_filter(sentences, timeout=args.model_timeout)
+        kept = [row for row in classified if row["finding"]]
+        filtered_count += len(classified) - len(kept)
+        per_intro[intro["arxiv_id"]] = {
+            "sentences": len(classified),
+            "finding_sentences": len(kept),
+            "staked": 0,
+            "no_match": 0,
+            "no_vote": 0,
+        }
+        for row in kept:
+            findings.append({**row, "arxiv_id": intro["arxiv_id"]})
+    timings["claim_filter_seconds"] = round(time.time() - t0, 3)
+
+    t0 = time.time()
+    finding_embeddings = embed_texts([row["sentence"] for row in findings], timeout=args.model_timeout) if findings else []
+    candidate_pairs: list[dict[str, Any]] = []
+    emergent_pool: list[dict[str, Any]] = []
+    for idx, (finding, emb) in enumerate(zip(findings, finding_embeddings)):
+        scores = [cosine(emb, base_emb) for base_emb in base_embeddings]
+        best_idx = max(range(len(scores)), key=lambda i: scores[i]) if scores else 0
+        best_score = scores[best_idx] if scores else 0.0
+        base_row = base[best_idx]
+        if best_score < args.tau_rel:
+            per_intro[finding["arxiv_id"]]["no_match"] += 1
+            emergent_pool.append({
+                "arxiv_id": finding["arxiv_id"],
+                "intro_sentence": finding["sentence"],
+                "max_cosine": round(best_score, 6),
+                "nearest_sentence_index": int(base_row["sentence_index"]),
+                "nearest_sentence_hash": base_row["sentence_hash"],
+                "nearest_base_sentence": base_row["sentence_text"],
+            })
+            continue
+        candidate_pairs.append({
+            "pair_id": f"pair-{idx}",
+            "arxiv_id": finding["arxiv_id"],
+            "intro_sentence": finding["sentence"],
+            "claim_filter_confidence": finding["confidence"],
+            "claim_filter_source": finding["source"],
+            "max_cosine": round(best_score, 6),
+            "page_version_id": int(base_row["page_version_id"]),
+            "sentence_index": int(base_row["sentence_index"]),
+            "sentence_hash": base_row["sentence_hash"],
+            "base_sentence": base_row["sentence_text"],
+        })
+    timings["embedding_match_seconds"] = round(time.time() - t0, 3)
+
+    t0 = time.time()
+    stance_rows = tone_gate_predictions(candidate_pairs, timeout=args.model_timeout)
+    timings["tone_gate_seconds"] = round(time.time() - t0, 3)
+
+    all_vote_candidates: list[dict[str, Any]] = []
+    for row in stance_rows:
+        stance, value = stance_from_tone(row["tone_tier"], float(row["tone_confidence"]), args.tau_vote)
+        out = {**row, "stance": stance, "value": value, "tau_vote": args.tau_vote, "sign_calibration": "UNCALIBRATED_pairwise_stance_gold_missing"}
+        all_vote_candidates.append(out)
+        if value is not None:
+            per_intro[row["arxiv_id"]]["staked"] += 1
+        else:
+            per_intro[row["arxiv_id"]]["no_vote"] += 1
+
+    rollup_rows = rollup(base, all_vote_candidates, args.tau_vote)
+    rollup_no_con = rollup(base, all_vote_candidates, args.tau_vote, drop_con=True)
+    rollup_low = rollup(base, all_vote_candidates, args.tau_vote - 0.10)
+    rollup_high = rollup(base, all_vote_candidates, args.tau_vote + 0.10)
+
+    def changed(left: list[dict[str, Any]], right: list[dict[str, Any]]) -> int:
+        by_idx = {row["sentence_index"]: row for row in right}
+        return sum(1 for row in left if row["would_be_trust_level"] != by_idx[row["sentence_index"]]["would_be_trust_level"])
+
+    staked_intros = sum(1 for row in per_intro.values() if row["staked"] > 0)
+    no_match_intros = sum(1 for row in per_intro.values() if row["no_match"] > 0 and row["staked"] == 0)
+    no_op_intros = len(intros) - staked_intros
+    staked_sentences = sum(row["new_pro_votes"] + row["new_con_votes"] > 0 for row in rollup_rows)
+    total_votes = sum(row["new_pro_votes"] + row["new_con_votes"] for row in rollup_rows)
+    total_settled = sum(row["would_be_settled_votes"] for row in rollup_rows)
+    total_contested = sum(row["would_be_contested_votes"] for row in rollup_rows)
+    tier_counts = collections.Counter(row["would_be_trust_level"] for row in rollup_rows)
+    summary = {
+        "task": "page58_sentence_vote_staking_dry_run",
+        "artifact_dir": str(args.out_dir),
+        "page_id": PAGE_ID,
+        "page_slug": PAGE_SLUG,
+        "page_version_id": meta["page_version"]["id"],
+        "page_version_num": meta["page_version"]["version_num"],
+        "thresholds": {"tau_rel": args.tau_rel, "tau_vote": args.tau_vote, "tau_vote_placeholder": True, "tau_rel_placeholder": True},
+        "models": {"claim_filter": ATOM_MODEL, "embedding": EMBED_MODEL, "tone_gate_source": str(TONE_GATE)},
+        "sign_calibration": "UNCALIBRATED_pairwise_stance_gold_missing",
+        "db_write_count": 0,
+        "no_apply": True,
+        "local_only": True,
+        "paid_lane_touched": False,
+        "claude_p_used": False,
+        "git_head_required": "4ba9675",
+        "git_head_observed": os.popen(f"git -C {REPO_ROOT} rev-parse --short HEAD").read().strip(),
+        "input_intros": len(intros),
+        "base_sentences": len(base),
+        "ratios": {
+            "intros_staked": f"{staked_intros}/{len(intros)}",
+            "intros_no_op": f"{no_op_intros}/{len(intros)}",
+            "intros_no_match_emergent_pool": f"{no_match_intros}/{len(intros)}",
+            "finding_sentences_kept": f"{len(findings)}/{sentence_count}" if sentence_count else "0/0",
+            "finding_sentences_filtered": f"{filtered_count}/{sentence_count}" if sentence_count else "0/0",
+            "provenance_coverage": f"{staked_sentences}/{len(base)}",
+            "settled_share": f"{total_settled}/{total_settled + total_contested}" if (total_settled + total_contested) else "0/0",
+        },
+        "counts": {
+            "split_sentences": sentence_count,
+            "finding_sentences": len(findings),
+            "filtered_sentences": filtered_count,
+            "matched_findings": len(candidate_pairs),
+            "emergent_pool_sentences": len(emergent_pool),
+            "emergent_pool_intros": no_match_intros,
+            "new_votes": total_votes,
+            "new_pro_votes": sum(row["new_pro_votes"] for row in rollup_rows),
+            "new_con_votes": sum(row["new_con_votes"] for row in rollup_rows),
+            "refine_tally": sum(row["refine_tally"] for row in rollup_rows),
+        },
+        "trust_distribution": {key: {"count": tier_counts[key], "ratio": f"{tier_counts[key]}/{len(base)}"} for key in sorted(tier_counts)},
+        "sensitivity": {
+            "trust_tier_changes_if_con_votes_dropped": f"{changed(rollup_rows, rollup_no_con)}/{len(base)}",
+            "trust_tier_changes_if_tau_vote_minus_0_10": f"{changed(rollup_rows, rollup_low)}/{len(base)}",
+            "trust_tier_changes_if_tau_vote_plus_0_10": f"{changed(rollup_rows, rollup_high)}/{len(base)}",
+        },
+        "timings": {**timings, "total_seconds": round(time.time() - started, 3)},
+        "created_at": dt.datetime.now(dt.UTC).isoformat(),
+    }
+    args.out_dir.mkdir(parents=True, exist_ok=True)
+    write_json(args.out_dir / "summary.json", summary)
+    write_jsonl(args.out_dir / "vote_candidates.jsonl", all_vote_candidates)
+    write_jsonl(args.out_dir / "emergent_pool.jsonl", emergent_pool)
+    write_jsonl(args.out_dir / "would_be_sentence_trust.jsonl", rollup_rows)
+    write_json(args.out_dir / "per_intro.json", per_intro)
+    write_report(args.out_dir / "REPORT.md", summary, rollup_rows)
+    return summary
+
+
+def pct(ratio: str) -> str:
+    left, right = ratio.split("/")
+    left_i, right_i = int(left), int(right)
+    return f"{(left_i / right_i * 100):.1f}%" if right_i else "n/a"
+
+
+def write_report(path: Path, summary: dict[str, Any], trust_rows: list[dict[str, Any]]) -> None:
+    lines = [
+        "# Page-58 Paper-Driven Vote Accumulation Dry Run",
+        "",
+        "Slice 1 only. No Alembic migration was applied and no production DB/page data was written.",
+        "",
+        "## Headline Ratios",
+        "",
+        f"- Intros that staked: {summary['ratios']['intros_staked']} ({pct(summary['ratios']['intros_staked'])}); no-op intros: {summary['ratios']['intros_no_op']} ({pct(summary['ratios']['intros_no_op'])}).",
+        f"- No-match intros routed to emergent pool: {summary['ratios']['intros_no_match_emergent_pool']} ({pct(summary['ratios']['intros_no_match_emergent_pool'])}).",
+        f"- Finding-class sentences kept: {summary['ratios']['finding_sentences_kept']} ({pct(summary['ratios']['finding_sentences_kept'])}); filtered: {summary['ratios']['finding_sentences_filtered']} ({pct(summary['ratios']['finding_sentences_filtered'])}).",
+        f"- Provenance coverage after new stakes: {summary['ratios']['provenance_coverage']} ({pct(summary['ratios']['provenance_coverage'])}).",
+        f"- Settled share after rollup: {summary['ratios']['settled_share']} ({pct(summary['ratios']['settled_share'])}).",
+        "",
+        "## Calibration Warning",
+        "",
+        "The pro/con sign is UNCALIBRATED. This run uses placeholder tau_rel=0.55 and tau_vote=0.70, plus the existing tone gate as a proxy. Pairwise stance gold is required before any write path.",
+        "",
+        "## Sensitivity",
+        "",
+        f"- Trust tier changes if con-votes are dropped: {summary['sensitivity']['trust_tier_changes_if_con_votes_dropped']}.",
+        f"- Trust tier changes if tau_vote shifts -0.10: {summary['sensitivity']['trust_tier_changes_if_tau_vote_minus_0_10']}.",
+        f"- Trust tier changes if tau_vote shifts +0.10: {summary['sensitivity']['trust_tier_changes_if_tau_vote_plus_0_10']}.",
+        "",
+        "## Per-Base-Sentence Rollup",
+        "",
+    ]
+    for row in trust_rows:
+        lines.extend([
+            f"### Sentence {row['sentence_index']}",
+            "",
+            row["sentence_text"],
+            "",
+            f"- New votes: +{row['new_pro_votes']} / -{row['new_con_votes']}; refine tally {row['refine_tally']}; no-op tally {row['no_op_tally']}.",
+            f"- Would-be trust: {row['would_be_trust_level']} (baseline {row['baseline_trust_level']}); settled share {row['settled_share']:.3f}.",
+            "",
+        ])
+    lines.extend([
+        "## Timing",
+        "",
+        *[f"- {key}: {value}s" for key, value in summary["timings"].items()],
+        "",
+        "## Containment",
+        "",
+        f"- db_write_count={summary['db_write_count']}",
+        f"- no_apply={summary['no_apply']}",
+        f"- local_only={summary['local_only']}",
+        f"- paid_lane_touched={summary['paid_lane_touched']}",
+        f"- claude_p_used={summary['claude_p_used']}",
+    ])
+    path.write_text("\n".join(lines) + "\n", encoding="utf-8")
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--no-apply", action="store_true")
+    parser.add_argument("--limit-intros", type=int)
+    parser.add_argument("--tau-rel", type=float, default=TAU_REL_DEFAULT)
+    parser.add_argument("--tau-vote", type=float, default=TAU_VOTE_DEFAULT)
+    parser.add_argument("--model-timeout", type=int, default=240)
+    parser.add_argument("--out-dir", type=Path, default=DOCS_ROOT / f"page58_sentence_vote_staking_dry_run_{utc_stamp()}")
+    args = parser.parse_args()
+    summary = run(args)
+    print(json.dumps(summary, ensure_ascii=False, indent=2, sort_keys=True))
+
+
+if __name__ == "__main__":
+    main()
