    },
    {
      "claim_type": "established",
      "id": 2931,
      "order_idx": 3,
      "text": "Galaxy quenching is jointly regulated by stellar mass as the primary driver and environment as a secondary modulator, with separable effects.",
      "trust_level": "unverified"
    },
    {
      "claim_type": "established",
      "id": 2932,
      "order_idx": 4,
      "text": "Galaxy environment correlates with morphological transformation and color evolution, with dense regions hosting predominantly quenched early-type systems.",
      "trust_level": "unverified"
    },
    {
      "claim_type": "established",
      "id": 2933,
      "order_idx": 5,
      "text": "Environmental quenching signatures, including ram-pressure stripping, are observed at high redshift, linking environment to rapid quenching in the early Universe.",
      "trust_level": "unverified"
    },
    {
      "claim_type": "established",
      "id": 2934,
      "order_idx": 6,
      "text": "Satellite galaxies experience environmental quenching after infall into groups or clusters, distinct from mass-driven quenching in centrals.",
      "trust_level": "unverified"
    },
    {
      "claim_type": "established",
      "id": 2935,
      "order_idx": 7,
      "text": "Cosmic-web environments like filaments and sheets shape galaxy evolution through tidal fields that influence gas accretion and stripping.",
      "trust_level": "unverified"
    },
    {
      "claim_type": "established",
      "id": 2936,
      "order_idx": 8,
      "text": "Dense cluster and group environments accelerate galaxy transformation through hydrodynamical interactions with the intracluster medium (such as ram-pressure stripping) and gravitational effects.",
      "trust_level": "unverified"
    }
